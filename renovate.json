{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":dependencyDashboard"
    ],
    "packageRules": [
        {
            "matchUpdateTypes": ["patch"],
            "automerge": true
        },
        {
            "matchManagers": ["dockerfile", "docker-compose"],
            "pinDigests": true
        }
    ],
    "lockFileMaintenance": {
        "enabled": true,
        "schedule": ["before 6am on monday"]
    }
}
