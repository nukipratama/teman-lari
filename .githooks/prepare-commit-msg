#!/usr/bin/env bash
# Auto-append a context entry to CHANGELOG.md on every regular commit.
# Vibe-coding journal: a single line of "what + why" lives in the commit
# subject, this hook stitches together the running record.

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# Skip merge / squash / amend / -F-from-file cases — those aren't fresh work.
case "$COMMIT_SOURCE" in
  merge|squash|commit) exit 0 ;;
esac

SUBJECT=$(grep -v '^#' "$COMMIT_MSG_FILE" | grep -v '^[[:space:]]*$' | head -n 1 || true)
[[ -z "$SUBJECT" ]] && exit 0   # let git's empty-message handling fire

CHANGELOG="CHANGELOG.md"
TIMESTAMP=$(date +"%Y-%m-%d %H:%M %z")
FILES=$(git diff --cached --name-only --diff-filter=ACMRTD | grep -v '^CHANGELOG\.md$' || true)

if [[ ! -f "$CHANGELOG" ]]; then
  printf "# Changelog\n\nAuto-generated context log for vibe-coded commits.\n\n" > "$CHANGELOG"
fi

{
  printf "## %s — %s\n\n" "$TIMESTAMP" "$SUBJECT"
  if [[ -n "$FILES" ]]; then
    printf "Files touched:\n"
    while IFS= read -r f; do
      printf -- "- \`%s\`\n" "$f"
    done <<< "$FILES"
  else
    printf "_No file changes._\n"
  fi
  printf "\n"
} >> "$CHANGELOG"

git add "$CHANGELOG"
