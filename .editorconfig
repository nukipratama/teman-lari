root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.{php,blade.php}]
indent_size = 4

[*.{js,ts,vue,jsx,tsx,json,yml,yaml,html,css,scss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[{compose,docker-compose}.{yml,yaml}]
indent_size = 4

[Makefile]
indent_style = tab
